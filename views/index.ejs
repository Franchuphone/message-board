
<h1>
    <%= locals.title %>
</h1>
<ul> 
    <% locals.messages.map((message) => { %>
        <li>
            <a href="/details/<%= message.id %>">
                <span><%= message.username + " says:" %></span>
                <span><%- message.message %></span>
                <span><%= "Sent at " + message.created_at.toLocaleString('fr-FR') %></span>
            </a>
        </li>
    <% }) %>
</ul>